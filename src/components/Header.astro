---
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects', children: projects.map((p) => ({ href: `/projects/${p.id}`, label: p.data.shortTitle || p.data.title })) },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-border">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="/" class="font-mono text-lg font-medium tracking-tight text-text hover:text-accent transition-colors">
      selvidata
    </a>

    <!-- Desktop nav -->
    <ul class="hidden gap-8 md:flex">
      {navLinks.map(({ href, label, children }) => (
        <li class:list={[children && 'relative group']}>
          <a
            href={href}
            class:list={[
              'text-sm transition-colors hover:text-text',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-text'
                : 'text-text-muted',
            ]}
          >
            {label}
            {children && (
              <svg class="ml-0.5 inline-block h-3 w-3 transition-transform group-hover:rotate-180" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 5l3 3 3-3" />
              </svg>
            )}
          </a>
          {children && (
            <ul class="invisible absolute left-1/2 top-full z-50 mt-2 min-w-[220px] -translate-x-1/2 rounded-lg border border-border bg-bg-secondary py-2 opacity-0 shadow-lg transition-all group-hover:visible group-hover:opacity-100">
              {children.map(({ href: childHref, label: childLabel }) => (
                <li>
                  <a
                    href={childHref}
                    class:list={[
                      'block px-4 py-2 text-sm transition-colors hover:bg-bg-tertiary hover:text-accent',
                      currentPath.startsWith(childHref) ? 'text-accent' : 'text-text-muted',
                    ]}
                  >
                    {childLabel}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="flex flex-col gap-1.5 md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="block h-0.5 w-5 bg-text-muted transition-all" id="bar1"></span>
      <span class="block h-0.5 w-5 bg-text-muted transition-all" id="bar2"></span>
      <span class="block h-0.5 w-5 bg-text-muted transition-all" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-border md:hidden">
    <ul class="mx-auto flex max-w-5xl flex-col px-6 py-4">
      {navLinks.map(({ href, label, children }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block py-2 text-sm transition-colors hover:text-text',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-text'
                : 'text-text-muted',
            ]}
          >
            {label}
          </a>
          {children && (
            <ul class="pl-4">
              {children.map(({ href: childHref, label: childLabel }) => (
                <li>
                  <a
                    href={childHref}
                    class:list={[
                      'block py-1.5 text-sm transition-colors hover:text-accent',
                      currentPath.startsWith(childHref) ? 'text-accent' : 'text-text-muted',
                    ]}
                  >
                    {childLabel}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
  });
</script>
