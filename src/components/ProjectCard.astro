---
interface Props {
  title: string;
  summary: string;
  client?: string;
  href?: string;
}

const { title, summary, client, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class="group block rounded-lg border border-border bg-bg-secondary p-6 transition-colors hover:border-accent/30"
>
  {client && <p class="mb-3 font-mono text-xs text-accent">{client}</p>}
  <h3 class="mb-2 text-lg font-medium text-text transition-colors group-hover:text-accent">{title}</h3>
  <p class="text-sm leading-relaxed text-text-muted">{summary}</p>
</Tag>
