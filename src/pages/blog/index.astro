---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="Articles on data engineering, analytics, and visualization.">
  <section class="py-8">
    <p class="mb-4 font-mono text-sm text-accent">Blog</p>
    <h1 class="mb-4 text-3xl font-light sm:text-4xl">Writing</h1>
    <p class="mb-10 text-text-muted leading-relaxed">
      Thoughts on data engineering, analytics, and building better data systems.
    </p>

    {posts.length === 0 ? (
      <p class="text-text-muted">No posts yet. Check back soon.</p>
    ) : (
      <div class="grid gap-4">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
            tags={post.data.tags}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
