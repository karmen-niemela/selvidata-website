---
import BaseLayout from '../layouts/BaseLayout.astro';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Karmen Niemela",
  "url": "https://selvidata.com/about",
  "image": "https://selvidata.com/profile_pic.png",
  "jobTitle": "Data Consultant",
  "worksFor": {
    "@type": "Organization",
    "name": "Selvi Data Consulting",
    "url": "https://selvidata.com"
  },
  "sameAs": [
    "https://www.linkedin.com/in/karmenniemela/",
    "https://github.com/kldykstra"
  ]
};
---

<BaseLayout title="About" description="About Selvi Data Consulting — a hands-on data professional with a passion for business impact.">
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <section class="py-8">
    <p class="mb-4 font-mono text-sm text-accent">About</p>
    <h1 class="mb-6 text-3xl font-light sm:text-4xl">About Me</h1>

    <!-- Motto -->
    <p class="mb-10 text-xl font-light leading-snug text-text">
      I am a hands-on data professional with a passion for business impact.
    </p>

    <!-- Credentials -->
    <ul class="mb-12 grid gap-3 sm:grid-cols-2">
      <li class="flex items-center gap-3 text-text-muted">
        <span class="text-accent">&#10003;</span> M.Sc. Machine Learning
      </li>
      <li class="flex items-center gap-3 text-text-muted">
        <span class="text-accent">&#10003;</span> 10 years as Data Analyst and Data Scientist
      </li>
      <li class="flex items-center gap-3 text-text-muted">
        <span class="text-accent">&#10003;</span> Extensive technical toolkit
      </li>
      <li class="flex items-center gap-3 text-text-muted">
        <span class="text-accent">&#10003;</span> Available for remote work worldwide
      </li>
    </ul>

    <!-- Bio with photo -->
    <div class="text-text-muted leading-relaxed">
      <img
        src="/profile_pic.png"
        alt="Karmen Niemela"
        class="float-left mr-8 mb-4 w-48 object-cover object-top sm:w-56"
      />
      <p class="mb-5">
        Through a combination of strong technical skills (Python, SQL, machine learning, experimentation, data engineering) and stakeholder communication, I specialize in uncovering insights from complex datasets and turning them into actionable strategies.
      </p>

      <p class="mb-5">
        I've worked with companies ranging from startups to global enterprises like Adobe, leading projects across product analytics, machine learning, and process optimization. Whether it's identifying the drivers of product performance, building models to accelerate R&D, or delivering concise dashboards and A/B test results, I focus on business impact — not just code.
      </p>

      <p class="mb-5">
        I'm available for freelance or contract work and can jump in to lead standalone projects, extend your team's capacity, or advise on your data strategy.
      </p>

      <p>
        Let's talk if you're looking for a reliable, senior-level data scientist who can hit the ground running.
      </p>
    </div>

    <!-- Social links -->
    <div class="mt-10 flex gap-4">
      <a
        href="https://www.linkedin.com/in/karmenniemela/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm text-text-muted transition-colors hover:border-text-muted hover:text-text"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
      <a
        href="https://github.com/kldykstra"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm text-text-muted transition-colors hover:border-text-muted hover:text-text"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
        GitHub
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12">
    <div class="rounded-lg border border-border bg-bg-secondary p-8 text-center">
      <p class="mb-3 text-xl font-light">Get insights now.</p>
      <p class="mb-6 text-text-muted">
        Build data flows and dashboards<br />to help your business grow.
      </p>
      <a
        href="/contact"
        class="inline-block rounded-lg bg-accent px-6 py-3 font-medium text-bg transition-colors hover:bg-accent-hover"
      >
        Start Now
      </a>
    </div>
  </section>
</BaseLayout>
